{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.framework.id": "astro",
  "frontMatter.preview.host": "http://localhost:4321",
  "frontMatter.content.publicFolder": "public",
  "frontMatter.content.defaultFileType": "mdx",
  "frontMatter.content.supportedFileTypes": [
    "mdx"
  ],
  "frontMatter.content.pageFolders": [
    {
      "title": "blog",
      "path": "[[workspace]]/src/content/news",
      "filePrefix": null
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "default",
      "filePrefix": null,
      "pageBundle": false,
      "fileType": "mdx",
      "template": ".frontmatter/templates/hir-sablon.mdx",
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string"
        },
        {
          "title": "FullTitle",
          "name": "fulltitle",
          "type": "string"
        },
        {
          "title": "Publishing date",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true
        },
        {
          "title": "id",
          "name": "id",
          "type": "number"
        },
        {
          "title": "excerpt",
          "name": "excerpt",
          "type": "string"
        },
        {
          "title": "lead",
          "name": "lead",
          "type": "string"
        },
        {
          "title": "image",
          "name": "image",
          "type": "image"
        }
      ]
    }
  ],
  "frontMatter.dashboard.openOnStart": false,
  "frontMatter.panel.openOnSupportedFile": false
}